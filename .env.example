# ── TMDB API Anahtarları ─────────────────────────────────────
# https://www.themoviedb.org/settings/api adresinden alın
# Birden fazla key virgülle ayırın (rate limit aşımında rotasyon yapar)
TMDB_API_KEYS=your_key_1,your_key_2,your_key_3

# ── TMDB-Embed-API (sorgumurat/TMDB-Embed-API) ───────────────
# Kendi sunucunuzda deploy ettiğiniz adres
# Boş bırakırsanız sadece statik embed URL'leri kullanılır
TMDB_EMBED_API_URL=http://localhost:4000

# ── Sunucu Ayarları ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
